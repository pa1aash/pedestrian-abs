\newlabel{fig:fd}{{2}{6}{Speed--density fundamental diagram, separated by steering configuration (\textbf {C1}: SFM only; \textbf {C2}: SFM+TTC; \textbf {C3}: SFM+ORCA; \textbf {C4}: full hybrid). Coloured curves: simulation mean (line) with $\pm $\,std band (shaded), bin centres marked. Grey: 4\,776 FZJ empirical points with their binned mean (dotted). Dashed: calibrated Weidmann reference. All four configurations yield nearly indistinguishable trends; the FD is determined by the Weidmann term, not by steering choice. Calibration reduces in-sample RMSE from 0.235 to 0.099\,m/s}{figure.caption.4}{}}
\newlabel{tab:ood}{{3}{6}{Held-out OOD validation: simulated vs.\ FZJ empirical bottleneck flow rates. All relative errors are negative (systematic underestimation)}{table.caption.5}{}}
\newlabel{tab:ood-per-paradigm}{{4}{6}{Per-paradigm OOD decomposition at $w=2.4$ and $3.6$\,m ($n=25$, $n_{\mathrm {agents}}=50$). $J_{\mathrm {sim}}$ mean\,$\pm $\,sd (ped/s) and relative error vs.\ $J_{\mathrm {emp}}$ (Table~\ref {tab:ood})}{table.caption.8}{}}
\newlabel{sec:force-diag}{{4.4}{6}{Density-Adaptive Gate}{subsection.4.4}{}}
\newlabel{fig:force}{{3}{7}{Force-component magnitudes vs.\ local Voronoi density (C4, $w=1.0$\,m, $n=5$ seeds, 55\,727 samples; per-seed median per log-spaced bin, across-seed mean $\pm $ 1\,std). The SFM and ORCA curves cross near $\rho \!\approx \!0.07$\,ped/m$^2$ (dotted). The gate centre $\rho _0 = 4.0$~ped/m$^2$ (dashed) is orders of magnitude above the observed density range, so the sigmoid functions as a fixed blend rather than an adaptive transition; scenarios that traverse the transition band are future work (\S \ref {sec:discussion})}{figure.caption.9}{}}
\newlabel{sec:ablation}{{4.5}{7}{Paradigm Ablation Across Scenarios}{subsection.4.5}{}}
\newlabel{tab:zonal}{{5}{7}{Mean contact-overlaps by spatial zone ($n=25$, mean\,$\pm $\,std)}{table.caption.10}{}}
\newlabel{fig:zonal}{{4}{7}{Contact-overlaps by zone at $w=1.0$\,m ($n=25$, mean $\pm $ std) after spawn-artefact removal (\S \ref {sec:ablation}). Persistent overlaps are rare and localise in the throat band (exit aperture); upstream and downstream zones are empty in all configurations. C2 and C4 (TTC-containing) are identically zero across every zone}{figure.caption.11}{}}
\newlabel{sec:bottleneck-evac}{{4.6}{8}{Bottleneck Deadlock and Mechanism}{subsection.4.6}{}}
\newlabel{fig:sigma-sweep}{{5}{9}{$C_1{+}\varepsilon $ deadlock-resolution probability vs.\ Gaussian velocity noise $\sigma $ ($w=0.8$\,m, 100 agents, $n=25$); $C_1{+}\varepsilon $ is plain SFM (\textbf {C1}) with per-step isotropic Gaussian velocity noise added to each agent. Blue: logistic fit. Vertical dotted line: $\sigma _{50}=0.049$\,m/s, 95\% CI $[0.044,0.053]$ (shaded). Horizontal dashed line: completion rate of the SFM+ORCA configuration \textbf {C3} (13/25) as a reference}{figure.caption.12}{}}
\newlabel{sec:external}{{4.7}{9}{External Simulator Comparison}{subsection.4.7}{}}
\newlabel{tab:bottleneck}{{6}{9}{Bottleneck evacuation time and contact-overlaps (mean\,$\pm $\,std, $n=25$; rejection-sampled initial placement, \S \ref {sec:ablation}). Evacuation time: $^{**}$\,$p_{\mathrm {HS}}\!<\!0.01$; $^{*}$\,$p_{\mathrm {HS}}\!<\!0.05$ for C1 vs.\ C4 via LMM. Contact-overlap counts after removing spawn-placement artefacts are rare events; C2 and C4 (TTC-containing) are identically zero at every tested width}{table.caption.13}{}}
\newlabel{fig:evac_width}{{6}{9}{Evacuation time vs.\ exit width for C1 and C4. Error bars: 95\% CIs, $n=25$}{figure.caption.14}{}}
\newlabel{fig:traj}{{7}{9}{Agent trajectories at $w=0.8$\,m (100 agents, seed 46). \textbf {Left:} C1 forms a stable arching deadlock at the exit throat. \textbf {Right:} C4 destabilises the arch and evacuates all 100 agents. Colour: normalised time}{figure.caption.15}{}}
\newlabel{tab:external}{{7}{10}{External simulator comparison at $w=1.0$\,m bottleneck, 50 agents, $n=25$ seeds. JuPedSim uses tool-default parameters (not tuned to match ours). JuPedSim SF did not complete evacuation in any seed within 60\,s; agents exited is reported instead of evacuation time}{table.caption.16}{}}
\newlabel{sec:scaling-eval}{{4.8}{10}{Computational Performance}{subsection.4.8}{}}
\newlabel{sec:discussion}{{5}{10}{\uppercase {Discussion}}{section.5}{}}
\newlabel{fig:scaling}{{8}{10}{Per-step wall-time scaling (log--log) for \textbf {C1} (SFM only) and \textbf {C4} (full hybrid: SFM+TTC+density-gated ORCA). C1 measured to 1\,000 agents; C4 to 500. ORCA introduces 29--36$\times $ overhead over SFM. Hardware: Apple M1, Python 3.13.12. Dotted line: real-time threshold (33\,ms/step at $\Delta t=0.01$\,s)}{figure.caption.17}{}}
